              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Dupont\",\n  \"prenom\": \"Jeanne\",\n  \"email\": \"{{collaborateur_email}}\",\n  \"contrat\": \"PORTAGE\",\n  \"seniorite\": \"CONFIRME\",\n  \"salaire\": \"42000\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/collaborateurs/{{collaborateur_id}}"
          },
          "response": []
        },
        {
          "name": "Toggle Activation Collaborateur",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": "{{baseUrl}}/api/collaborateurs/{{collaborateur_id}}/activation"
          },
          "response": []
        }
      ]
